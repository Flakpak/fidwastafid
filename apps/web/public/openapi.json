  "paths": {
    "/deals": {
      "get": {
        "summary": "Liste des deals (filtres, pagination par curseur)",
        "tags": [
          "deals"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "publie|expire — publie par défaut"
            },
            "required": false,
            "name": "statut",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "enseigne",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "ville",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "categorie",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "type",
            "in": "query"
          },
          {
            "schema": {
              "type": "string",
              "description": "tendance|score|recent — tendance par défaut"
            },
            "required": false,
            "name": "tri",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "cursor",
            "in": "query"
          },
          {
            "schema": {
              "type": "string"
            },
            "required": false,
            "name": "limit",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DealPage"
                }
              }
            }
          },
          "400": {
            "description": "Curseur invalide",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Soumission communautaire — toujours créé en_attente. Accepte aussi multipart/form-data avec un champ \"image\" optionnel (photo terrain, jpeg/png/webp, 5 Mo max — mêmes champs que le JSON, en valeurs texte).",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "tags": [
          "deals"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string",
              "description": "Cloudflare Turnstile"
            },
            "required": false,
            "name": "X-Turnstile-Token",
            "in": "header"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DealInput"
              }
            },
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/DealInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Créé",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Deal"
                }
              }
            }
          },
          "400": {
            "description": "Corps invalide, vérification anti-robot échouée, ou image invalide/trop volumineuse",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "401": {
            "description": "Authentification requise",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          },
          "429": {
            "description": "Trop de soumissions",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
    "/deals/{publicId}": {
      "get": {
        "summary": "Détail d'un deal (jamais 404 sur un deal expiré — CONTRAT-V1 §1)",
        "tags": [
          "deals"
        ],
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "publicId",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Deal"
                }
              }
            }
          },
          "404": {
            "description": "Deal introuvable ou non public",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiError"
                }
              }
            }
          }
        }
      }
    },
