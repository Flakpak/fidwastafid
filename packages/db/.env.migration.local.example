# Copier en .env.migration.local (jamais commité — cf. règle *.local du
# .gitignore racine) et renseigner les valeurs réelles. Syntaxe .env pure
# (CLE=valeur, sans export, sans $env:, sans guillemets) — ce fichier n'est
# jamais lu directement en conversation, seulement chargé par les scripts
# (packages/db/src/*.ts lisent process.env directement ; scripts/audit-v1.mjs
# parse ce fichier lui-même, pas de source shell requise), et les sorties de
# commande sont filtrées avant partage.

# Base v2 (aswbu, Session pooler) — utilisée par
# `pnpm --filter @fidwastafid/db migrate` / `seed` / `check-migrations-sync`.
DATABASE_URL=postgresql://user:password@host:port/database

# Base v1 (laqwg) — lecture seule, utilisée uniquement par scripts/audit-v1.mjs.
# Le rôle Postgres utilisé n'a besoin que de SELECT sur le schéma public
# (et idéalement auth.users, sinon la section correspondante de l'audit le
# signale comme non accessible plutôt que d'échouer).
V1_DATABASE_URL=postgresql://user:password@host:port/database
